<?php
header("Content-Type: application/json");
header("Access-Control-Allow-Origin: *");
header("Access-Control-Allow-Methods: GET, POST, DELETE, OPTIONS");
header("Access-Control-Allow-Headers: Content-Type");

include "config.php";
$method = $_SERVER['REQUEST_METHOD'];

/* ==================================================
   HELPER : UPSERT STOCK (NO DELETE)
================================================== */
function upsertStock(
    $conn,
    $product_id,
    $source_id,
    $net_weight,
    $quantity,
    $rate,
    $making,
    $batch_type,
    $date
){
    $total_amount = ($net_weight * $rate) + $making;

    // check existing stock
    $c = $conn->prepare("
        SELECT stock_id 
        FROM stock 
        WHERE batch_type=? AND source_id=? AND product_id=?
    ");
    $c->bind_param("sii", $batch_type, $source_id, $product_id);
    $c->execute();
    $old = $c->get_result()->fetch_assoc();

    if($old){
        // UPDATE stock
        $u = $conn->prepare("
            UPDATE stock SET
                net_weight=?,
                remaining_weight=?,
                quantity=?,
                remaining_qty=?,
                rate_per_gram=?,
                making_charge=?,
                total_amount=?,
                batch_date=?
            WHERE stock_id=?
        ");
        $u->bind_param(
            "dddddddsi",
            $net_weight,
            $net_weight,
            $quantity,
            $quantity,
            $rate,
            $making,
            $total_amount,
            $date,
            $old['stock_id']
        );
        $u->execute();
    } else {
        // INSERT stock
        $i = $conn->prepare("
            INSERT INTO stock
            (product_id,batch_type,source_id,batch_date,
             net_weight,remaining_weight,quantity,remaining_qty,
             rate_per_gram,making_charge,total_amount)
            VALUES (?,?,?,?,?,?,?,?,?,?,?)
        ");
        $i->bind_param(
            "isissddiddd",
            $product_id,
            $batch_type,
            $source_id,
            $date,
            $net_weight,
            $net_weight,
            $quantity,
            $quantity,
            $rate,
            $making,
            $total_amount
        );
        $i->execute();
    }
}

/* ==================================================
   CREATE / UPDATE PURCHASE
================================================== */
if($method === "POST"){
    $conn->begin_transaction();
    try{

        $purchase_id   = $_POST['purchase_id'] ?? null;
        $supplier_id   = $_POST['supplier_id'];
        $bill_no       = $_POST['bill_no'];
        $purchase_date = $_POST['purchase_date'];
        $tax_type      = $_POST['tax_type'];
        $tax_percent   = floatval($_POST['tax_percent']);
        $items         = json_decode($_POST['items'], true);

        if(!$items) throw new Exception("Items missing");

        /* ===== CALCULATE TOTAL ===== */
        $sub_total = 0;
        foreach($items as $i){
            $sub_total += floatval($i['total_amount']);
        }
        $tax_amount   = ($sub_total * $tax_percent) / 100;
        $grand_total  = $sub_total + $tax_amount;

        /* ===== PURCHASE HEADER ===== */
        if($purchase_id){
            // UPDATE purchase
            $stmt = $conn->prepare("
                UPDATE purchases SET
                    supplier_id=?,
                    bill_no=?,
                    purchase_date=?,
                    tax_type=?,
                    tax_percent=?,
                    tax_amount=?,
                    total_amount=?
                WHERE purchase_id=?
            ");
            $stmt->bind_param(
                "isssdddd",
                $supplier_id,
                $bill_no,
                $purchase_date,
                $tax_type,
                $tax_percent,
                $tax_amount,
                $grand_total,
                $purchase_id
            );
            $stmt->execute();

            // delete old items ONLY
            $conn->query("DELETE FROM purchase_items WHERE purchase_id=$purchase_id");

        } else {
            // INSERT purchase
            $stmt = $conn->prepare("
                INSERT INTO purchases
                (supplier_id,bill_no,purchase_date,tax_type,tax_percent,tax_amount,total_amount)
                VALUES (?,?,?,?,?,?,?)
            ");
            $stmt->bind_param(
                "isssddd",
                $supplier_id,
                $bill_no,
                $purchase_date,
                $tax_type,
                $tax_percent,
                $tax_amount,
                $grand_total
            );
            $stmt->execute();
            $purchase_id = $conn->insert_id;
        }

        /* ===== ITEMS + STOCK ===== */
        foreach($items as $i){
            $pid    = intval($i['product_id']);
            $w      = floatval($i['net_weight']);
            $q      = floatval($i['quantity']);
            $rate   = floatval($i['rate_per_gram']);
            $make   = floatval($i['making_charge']);
            $total  = floatval($i['total_amount']);

            // insert item
            $stmt = $conn->prepare("
                INSERT INTO purchase_items
                (purchase_id,product_id,net_weight,quantity,rate_per_gram,making_charge,total_amount)
                VALUES (?,?,?,?,?,?,?)
            ");
            $stmt->bind_param(
                "iiidddd",
                $purchase_id,
                $pid,
                $w,
                $q,
                $rate,
                $make,
                $total
            );
            $stmt->execute();

            // UPSERT stock ✅
            upsertStock(
                $conn,
                $pid,
                $purchase_id,
                $w,
                $q,
                $rate,
                $make,
                'purchase',
                $purchase_date
            );
        }

        $conn->commit();
        echo json_encode(["status"=>"success","message"=>"Purchase saved"]);

    } catch(Exception $e){
        $conn->rollback();
        echo json_encode(["status"=>"error","message"=>$e->getMessage()]);
    }
    exit;
}

/* ==================================================
   READ PURCHASES
================================================== */
if($method === "GET"){
    $arr = [];
    $res = $conn->query("SELECT * FROM purchases ORDER BY purchase_id DESC");
    while($p = $res->fetch_assoc()){
        $pid = $p['purchase_id'];
        $items = [];
        $r2 = $conn->query("SELECT * FROM purchase_items WHERE purchase_id=$pid");
        while($i = $r2->fetch_assoc()) $items[] = $i;
        $p['items'] = $items;
        $arr[] = $p;
    }
    echo json_encode(["status"=>"success","data"=>$arr]);
    exit;
}

/* ==================================================
   DELETE PURCHASE
================================================== */
if($method === "DELETE"){
    $d = json_decode(file_get_contents("php://input"),true);
    $pid = $d['purchase_id'];

    $conn->begin_transaction();
    try{
        $conn->query("DELETE FROM stock WHERE batch_type='purchase' AND source_id=$pid");
        $conn->query("DELETE FROM purchase_items WHERE purchase_id=$pid");
        $conn->query("DELETE FROM purchases WHERE purchase_id=$pid");
        $conn->commit();
        echo json_encode(["status"=>"success"]);
    }catch(Exception $e){
        $conn->rollback();
        echo json_encode(["status"=>"error","message"=>$e->getMessage()]);
    }
    exit;
}

echo json_encode(["status"=>"error","message"=>"Invalid request"]);
