/* =================== HELPER: UPSERT STOCK =================== */
function upsertStock($conn, $product_id, $opening_stock_id, $net_weight, $quantity, $rate, $making, $total_amount, $batch_date = null) {
    $batch_date = $batch_date ?? date("Y-m-d H:i:s");

    $stmt = $conn->prepare("SELECT stock_id FROM stock WHERE batch_type='opening' AND source_id=?");
    $stmt->bind_param("i", $opening_stock_id);
    $stmt->execute();
    $stock = $stmt->get_result()->fetch_assoc();

    if ($stock) {
        // UPDATE existing stock
        $u = $conn->prepare("
            UPDATE stock SET
                net_weight=?,
                remaining_weight=?,
                quantity=?,
                remaining_qty=?,
                rate_per_gram=?,
                making_charge=?,
                total_amount=?,
                batch_date=?
            WHERE stock_id=?
        ");
        $u->bind_param("dddddddsi", $net_weight, $net_weight, $quantity, $quantity, $rate, $making, $total_amount, $batch_date, $stock['stock_id']);
        $u->execute();
    } else {
        // INSERT new stock
        $batch_type = 'opening';
        $i = $conn->prepare("
            INSERT INTO stock
            (product_id,batch_type,source_id,batch_date,net_weight,remaining_weight,quantity,remaining_qty,rate_per_gram,making_charge,total_amount)
            VALUES (?,?,?,?,?,?,?,?,?,?,?)
        ");
        $i->bind_param("isissddiddd", $product_id, $batch_type, $opening_stock_id, $batch_date, $net_weight, $net_weight, $quantity, $quantity, $rate, $making, $total_amount);
        $i->execute();
    }
}

/* =================== CREATE / UPDATE OPENING STOCK =================== */
if ($method === "POST") {
    $d = json_decode(file_get_contents("php://input"), true);

    $product_id   = (int)($d['product_id'] ?? 0);
    $net_weight   = (float)($d['net_weight'] ?? 0);
    $quantity     = (float)($d['quantity'] ?? 0);
    $rate         = (float)($d['rate_per_gram'] ?? 0);
    $making       = (float)($d['making_charge'] ?? 0);
    $total_amount = (float)($d['total_amount'] ?? 0);
    $entry_date   = $d['entry_date'] ?? date("Y-m-d H:i:s");

    $conn->begin_transaction();
    try {
        // Check if opening_stock exists for this product_id
        $c = $conn->prepare("SELECT * FROM opening_stock WHERE product_id=?");
        $c->bind_param("i", $product_id);
        $c->execute();
        $old = $c->get_result()->fetch_assoc();

        if ($old) {
            // UPDATE existing opening_stock
            $u = $conn->prepare("
                UPDATE opening_stock SET
                    net_weight=?,
                    quantity=?,
                    rate_per_gram=?,
                    making_charge=?,
                    total_amount=?,
                    entry_date=?
                WHERE opening_stock_id=?
            ");
            $u->bind_param("dddddsi", $net_weight, $quantity, $rate, $making, $total_amount, $entry_date, $old['opening_stock_id']);
            $u->execute();
            $opening_stock_id = $old['opening_stock_id'];
        } else {
            // INSERT new opening_stock
            $i = $conn->prepare("
                INSERT INTO opening_stock
                (product_id,net_weight,quantity,rate_per_gram,making_charge,total_amount,entry_date)
                VALUES (?,?,?,?,?,?,?)
            ");
            $i->bind_param("ididdis", $product_id, $net_weight, $quantity, $rate, $making, $total_amount, $entry_date);
            $i->execute();
            $opening_stock_id = $conn->insert_id;
        }

        // UPSERT stock
        upsertStock($conn, $product_id, $opening_stock_id, $net_weight, $quantity, $rate, $making, $total_amount, $entry_date);

        $conn->commit();
        echo json_encode(["status" => "success", "message" => "Opening stock inserted/updated successfully"]);
    } catch (Exception $e) {
        $conn->rollback();
        echo json_encode(["status" => "error", "message" => $e->getMessage()]);
    }
    exit;
}

/* =================== READ ALL =================== */
if ($method === "GET") {
    $q = $conn->query("
        SELECT os.*, p.product_name, p.purity
        FROM opening_stock os
        JOIN products p ON p.product_id=os.product_id
        ORDER BY os.opening_stock_id DESC
    ");
    $data = [];
    while ($r = $q->fetch_assoc()) $data[] = $r;
    echo json_encode(["status" => "success", "data" => $data]);
    exit;
}

/* =================== DELETE =================== */
if ($method === "DELETE") {
    $d = json_decode(file_get_contents("php://input"), true);
    $id = (int)($d['opening_stock_id'] ?? 0);

    $conn->begin_transaction();
    try {
        // Delete stock first
        $conn->query("DELETE FROM stock WHERE batch_type='opening' AND source_id=$id");
        // Delete opening_stock
        $conn->query("DELETE FROM opening_stock WHERE opening_stock_id=$id");

        $conn->commit();
        echo json_encode(["status" => "success", "message" => "Deleted successfully"]);
    } catch (Exception $e) {
        $conn->rollback();
        echo json_encode(["status" => "error", "message" => $e->getMessage()]);
    }
    exit;
}

echo json_encode(["status" => "error", "message" => "Invalid request"]);
